{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LEOS",
  "version": "0.3.0",
  "identifier": "works.holagundi.leos",
  "build": {
    "devUrl": "http://localhost:5174",
    "frontendDist": "../frontend/dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": "node scripts/prepare-build.mjs"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LEOS — Learning Environment Operating System",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/leos-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
